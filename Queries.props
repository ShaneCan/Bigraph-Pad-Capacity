// =====================================================================
// PRISM query templates for the eVTOL vertiport CTMC models.
//
// BigraphER exports, for every model/parameter combination:
//     <model>.tra    transition matrix (CTMC, rate-labelled)
//     <model>.csl    label definitions (atomic propositions over state x)
//     <model>.rews   state rewards (throughput = 60 × R=?[S])
//
// PRISM is invoked as
//     prism -importtrans <model>.tra \
//           -importstaterewards <model>.rews -ctmc \
//           <props> -gs -maxiters 1000000
// where <props> = the generated <model>.csl  followed by the queries
// below (the label definitions must precede the queries).  Gauss-Seidel
// (-gs) is required for the steady-state solves to converge.
//
// The analysis scripts assemble these automatically; this file documents
// the meaning of each query.
// =====================================================================

// ---- Capacity / throughput (flights per hour = 60 × R=?[S]) -------
// State reward on pad-departing.
// Each take-off = one flight.
R=? [ S ]

// ---- Pad utilisation (single-pad layouts V1 / V2) -------------------
S=? [ "fato_landing" ]      // P(pad busy with a landing)
S=? [ "fato_departing" ]    // P(pad busy with a departure)
S=? [ "pad_free" ]          // P(pad idle / available)

// ---- Pad utilisation (dual-pad layout V3) ---------------------------
S=? [ "small_pad_landing" ]
S=? [ "small_pad_departing" ]
S=? [ "large_pad_landing" ]
S=? [ "large_pad_departing" ]
S=? [ "large_pad_landing_small" ]     // small aircraft using LargeFATO
S=? [ "large_pad_departing_small" ]   // small aircraft using LargeFATO

// ---- Congestion -----------------------------------------------------
S=? [ "all_stands_busy" ]   // P(every stand occupied)

// ---- V3 one-way transit blocking ------------------------------------
// Labels are parameterised by waiting count; scripts query _1/_2 as needed.
S=? [ "small_transit_blocked_1" ]
S=? [ "large_transit_blocked_1" ]

// ---- Open M/M/c/K arrivals (Vertiport_V1_Open / V2_Open) -------------
// Blocking/loss probability by PASTA: external arrivals see time averages.
S=? [ "approach_full" ]
// Mean counts are computed by scripts from labels app_count_i,
// taxi_in_count_i, taxi_out_count_i, svc_count_i, rdy_count_i,
// pad_in_system and pad_out_system:
//   L = sum_i i * S=?["app_count_i"] + ...
//   delay = L / (lambda_eff), lambda_eff = arrival_rate * (1-P_block)

// ---- Resilience (Vertiport_V1_Resilience_*_SBrs) --------------------
// Pad:    S=? [ "pad_closed" ]
// Stand:  S=? [ "stands_out_1" ]
// Weather: S=? [ "weather_bad" ], S=? [ "nominal" ]
// Turnaround: rate_service via -c (no fault states)
// Throughput (R=?[S]) is evaluated while sweeping fault_rate or turnaround time;
// fig4 compares degraded throughput against the plain V1 nominal baseline at N=6.
